#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# add_machine  —  Register a new machine
#
# Usage:
#   Interactive:   ./add_machine.sh --interactive
#   One-liner:     ./add_machine.sh -m worker-01 -p x86_64 [options]
#   Batch mode:   ./add_machine.sh -m worker-01 -p x86_64 --yes
#
# Required: -m (machine_name) and -p (platform_name)
# All other fields are optional.
#
# Options:
#   -m  machine name      (required)
#   -p  platform          (required)
#   --interactive         guided prompt mode
#   --help
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ── defaults ──────────────────────────────────────────────────────────────────
CONFIG_DIR="/usr/local/etc"
source ${CONFIG_DIR}/machines.config

# ── field variables ───────────────────────────────────────────────────────────
MACHINE_NAME=""
PLATFORM_NAME=""
IP_ADDRESS=""
BMC_NAME=""
OS=""
DESCRIPTION=""
PO_SMS=""
PROGRAM=""
SOCKET=""
SYSTEM_CONFIG=""
MAKE=""
MODEL=""
CATEGORY=""
ASSET_OWNER=""
SERIAL=""
MAAS_SWITCH=""
PDU_IP=""
PDU_PORT=""
SITE=""
LAB=""
ROW_LOCATION=""
RACK=""
RU=""
CPU=""
BACKPLANE=""
JIRA=""

INTERACTIVE=false
BATCH=false

# ── colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m';  GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m';     RESET='\033[0m'

# ── usage ─────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF

${BOLD}add_machine.sh${RESET} — Register a new machine
Server: ${SERVER}

${BOLD}INTERACTIVE MODE${RESET}
  $(basename "$0") --interactive

${BOLD}FLAG MODE${RESET}
  $(basename "$0") -m <machine> -p <platform> [options]

${BOLD}REQUIRED FLAGS${RESET}
  -m   machine name
  -p   platform name

${BOLD}OPTIONAL FLAGS — identity${RESET}
  -i   IP address
  -b   BMC name
  -o   OS
  -d   description

${BOLD}OPTIONAL FLAGS — inventory${RESET}
  --po-sms <val>        PO/SMS number
  --program <val>       program name
  --socket <val>        socket type
  --sys-config <val>    system configuration
  --make <val>          manufacturer
  --model <val>         model name
  --category <val>      category
  --asset-owner <val>   asset owner
  --serial <val>        serial number
  --maas-switch <val>   MaaS switch
  --pdu-ip <val>        PDU IP address
  --pdu-port <val>      PDU port
  --site <val>          site location
  --lab <val>           lab name
  --row <val>           row location
  --rack <val>          rack identifier
  --ru <val>            rack unit
  --cpu <val>           CPU type
  --backplane <val>     backplane type
  --jira <val>          JIRA ticket

${BOLD}OTHER FLAGS${RESET}
  -y / --yes            batch mode — skip confirmation
  --interactive         guided prompt mode
  --help

${BOLD}EXAMPLES${RESET}
  $(basename "$0") --interactive
  $(basename "$0") -m worker-01 -p x86_64
  $(basename "$0") -m worker-01 -p x86_64 -i 10.0.1.42 -o "RHEL 9.3"
  $(basename "$0") -m worker-01 -p x86_64 --site Austin --rack R42 --cpu Turin
  $(basename "$0") -m worker-01 -p x86_64 --serial SN123 --jira PROJ-1234 --yes

EOF
    exit 0
}

# ─────────────────────────────────────────────────────────────────────────────
# Argument parsing
# ─────────────────────────────────────────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interactive)    INTERACTIVE=true;      shift ;;
            --yes|-y)         BATCH=true;            shift ;;
            --help|-h)        usage ;;
            -m)               MACHINE_NAME="$2";     shift 2 ;;
            -p)               PLATFORM_NAME="$2";    shift 2 ;;
            -i)               IP_ADDRESS="$2";       shift 2 ;;
            -b)               BMC_NAME="$2";         shift 2 ;;
            -o)               OS="$2";               shift 2 ;;
            -d)               DESCRIPTION="$2";      shift 2 ;;
            --po-sms)         PO_SMS="$2";           shift 2 ;;
            --program)        PROGRAM="$2";          shift 2 ;;
            --socket)         SOCKET="$2";           shift 2 ;;
            --sys-config)     SYSTEM_CONFIG="$2";    shift 2 ;;
            --make)           MAKE="$2";             shift 2 ;;
            --model)          MODEL="$2";            shift 2 ;;
            --category)       CATEGORY="$2";         shift 2 ;;
            --asset-owner)    ASSET_OWNER="$2";      shift 2 ;;
            --serial)         SERIAL="$2";           shift 2 ;;
            --maas-switch)    MAAS_SWITCH="$2";      shift 2 ;;
            --pdu-ip)         PDU_IP="$2";           shift 2 ;;
            --pdu-port)       PDU_PORT="$2";         shift 2 ;;
            --site)           SITE="$2";             shift 2 ;;
            --lab)            LAB="$2";              shift 2 ;;
            --row)            ROW_LOCATION="$2";     shift 2 ;;
            --rack)           RACK="$2";             shift 2 ;;
            --ru)             RU="$2";               shift 2 ;;
            --cpu)            CPU="$2";              shift 2 ;;
            --backplane)      BACKPLANE="$2";        shift 2 ;;
            --jira)           JIRA="$2";             shift 2 ;;
            *)
                printf "${RED}Unknown option: %s${RESET}\n" "$1" >&2
                printf "Run with --help for usage.\n" >&2
                exit 1
                ;;
        esac
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Prompt helpers
# ─────────────────────────────────────────────────────────────────────────────

ask() {
    local var="$1" prompt="$2" current="${3:-}" value=""

    if [[ -n "$current" ]]; then
        printf "${CYAN}?${RESET} ${BOLD}%-30s${RESET} ${YELLOW}[%s]${RESET}: " \
               "$prompt" "$current"
    else
        printf "${CYAN}?${RESET} ${BOLD}%-30s${RESET}: " "$prompt"
    fi

    read -r value
    if [[ -z "$value" ]]; then
        value="$current"
    fi
    printf -v "$var" '%s' "$value"
}

ask_required() {
    local var="$1" prompt="$2" current="${3:-}"

    while true; do
        ask "$var" "$prompt" "$current"
        local val
        eval val="\$$var"
        local stripped="${val//[[:space:]]/}"
        if [[ -n "$stripped" ]]; then
            return
        fi
        printf "${RED}  ✗  This field is required.${RESET}\n"
    done
}

ask_yes_no() {
    local var="$1" prompt="$2" default="${3:-n}"

    if [[ "$BATCH" == true ]]; then
        local auto
        if [[ "$default" == "y" ]]; then
            auto="true"
        else
            auto="false"
        fi
        printf "${CYAN}?${RESET} ${BOLD}%s${RESET} ${YELLOW}[batch: %s — auto-accepted]${RESET}\n" \
               "$prompt" "$default"
        printf -v "$var" '%s' "$auto"
        return
    fi

    local hint
    if [[ "$default" == "y" ]]; then
        hint="Y/n"
    else
        hint="y/N"
    fi

    while true; do
        printf "${CYAN}?${RESET} ${BOLD}%s${RESET} ${YELLOW}[%s]${RESET}: " \
               "$prompt" "$hint"
        local value=""
        read -r value
        if [[ -z "$value" ]]; then
            value="$default"
        fi

        case "${value,,}" in
            y|yes)  printf -v "$var" 'true';  return ;;
            n|no)   printf -v "$var" 'false'; return ;;
            *)      printf "${RED}  Please type y or n.${RESET}\n" ;;
        esac
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Summary display
# ─────────────────────────────────────────────────────────────────────────────

_print_field() {
    local label="$1" value="$2"
    printf "  ${BOLD}%-20s${RESET} %s\n" "$label:" "${value:-(none)}"
}

print_summary() {
    echo ""
    printf "${BOLD}${YELLOW}── Summary ──────────────────────────────────${RESET}\n"

    # identity
    _print_field "Machine name"    "$MACHINE_NAME"
    _print_field "Platform"        "$PLATFORM_NAME"
    _print_field "IP address"      "$IP_ADDRESS"
    _print_field "BMC name"        "$BMC_NAME"
    _print_field "OS"              "$OS"
    _print_field "Description"     "$DESCRIPTION"

    # check if any inventory fields are set
    local has_inventory=false
    for v in "$PO_SMS" "$PROGRAM" "$SOCKET" "$SYSTEM_CONFIG" "$MAKE" "$MODEL" \
             "$CATEGORY" "$ASSET_OWNER" "$SERIAL" "$MAAS_SWITCH" "$PDU_IP" \
             "$PDU_PORT" "$SITE" "$LAB" "$ROW_LOCATION" "$RACK" "$RU" "$CPU" \
             "$BACKPLANE" "$JIRA"; do
        if [[ -n "$v" ]]; then
            has_inventory=true
            break
        fi
    done

    if [[ "$has_inventory" == true ]]; then
        echo ""
        printf "  ${CYAN}── Inventory ──${RESET}\n"
        _print_field "PO/SMS"          "$PO_SMS"
        _print_field "Program"         "$PROGRAM"
        _print_field "Socket"          "$SOCKET"
        _print_field "System Config"   "$SYSTEM_CONFIG"
        _print_field "Make"            "$MAKE"
        _print_field "Model"           "$MODEL"
        _print_field "Category"        "$CATEGORY"
        _print_field "Asset Owner"     "$ASSET_OWNER"
        _print_field "Serial"          "$SERIAL"
        _print_field "MaaS Switch"     "$MAAS_SWITCH"
        _print_field "PDU IP"          "$PDU_IP"
        _print_field "PDU Port"        "$PDU_PORT"
        _print_field "Site"            "$SITE"
        _print_field "Lab"             "$LAB"
        _print_field "Row"             "$ROW_LOCATION"
        _print_field "Rack"            "$RACK"
        _print_field "RU"              "$RU"
        _print_field "CPU"             "$CPU"
        _print_field "Backplane"       "$BACKPLANE"
        _print_field "JIRA"            "$JIRA"
    fi

    echo ""
    _print_field "Server"          "$SERVER"
    printf "${BOLD}${YELLOW}─────────────────────────────────────────────${RESET}\n"
    echo ""
}

# ─────────────────────────────────────────────────────────────────────────────
# Interactive mode
# ─────────────────────────────────────────────────────────────────────────────

run_interactive() {
    echo ""
    printf "${BOLD}${GREEN}════════════════════════════════════════════${RESET}\n"
    printf "${BOLD}${GREEN}  Add Machine  —  %s${RESET}\n" "$SERVER"
    printf "${BOLD}${GREEN}════════════════════════════════════════════${RESET}\n"
    printf "  ${YELLOW}* = required.  Press Enter to skip optional fields.${RESET}\n"
    echo ""

    printf "  ${CYAN}── Identity ──${RESET}\n"
    ask_required MACHINE_NAME  "* Machine name"       "$MACHINE_NAME"
    ask_required PLATFORM_NAME "* Platform"            "$PLATFORM_NAME"
    ask          IP_ADDRESS    "  IP address"           "$IP_ADDRESS"
    ask          BMC_NAME      "  BMC name"             "$BMC_NAME"
    ask          OS            "  Operating system"     "$OS"
    ask          DESCRIPTION   "  Description"          "$DESCRIPTION"

    echo ""
    printf "  ${CYAN}── Inventory (all optional) ──${RESET}\n"
    ask          PO_SMS        "  PO/SMS"               "$PO_SMS"
    ask          PROGRAM       "  Program"              "$PROGRAM"
    ask          SOCKET        "  Socket"               "$SOCKET"
    ask          SYSTEM_CONFIG "  System Config"        "$SYSTEM_CONFIG"
    ask          MAKE          "  Make"                 "$MAKE"
    ask          MODEL         "  Model"                "$MODEL"
    ask          CATEGORY      "  Category"             "$CATEGORY"
    ask          ASSET_OWNER   "  Asset Owner"          "$ASSET_OWNER"
    ask          SERIAL        "  Serial"               "$SERIAL"
    ask          MAAS_SWITCH   "  MaaS Switch"          "$MAAS_SWITCH"
    ask          PDU_IP        "  PDU IP"               "$PDU_IP"
    ask          PDU_PORT      "  PDU Port"             "$PDU_PORT"

    echo ""
    printf "  ${CYAN}── Location (all optional) ──${RESET}\n"
    ask          SITE          "  Site"                 "$SITE"
    ask          LAB           "  Lab"                  "$LAB"
    ask          ROW_LOCATION  "  Row"                  "$ROW_LOCATION"
    ask          RACK          "  Rack"                 "$RACK"
    ask          RU            "  RU"                   "$RU"

    echo ""
    printf "  ${CYAN}── Hardware / Tracking ──${RESET}\n"
    ask          CPU           "  CPU"                  "$CPU"
    ask          BACKPLANE     "  Backplane"            "$BACKPLANE"
    ask          JIRA          "  JIRA ticket"          "$JIRA"

    print_summary

    local CONFIRMED
    ask_yes_no CONFIRMED "Submit?" "y"

    if [[ "$CONFIRMED" == false ]]; then
        printf "${YELLOW}  Aborted. Nothing was sent.${RESET}\n\n"
        exit 0
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Flag mode validation
# ─────────────────────────────────────────────────────────────────────────────

run_flag_mode() {
    local errors=()
    if [[ -z "$MACHINE_NAME" ]]; then
        errors+=("  -m machine name is required")
    fi
    if [[ -z "$PLATFORM_NAME" ]]; then
        errors+=("  -p platform is required")
    fi

    if [[ ${#errors[@]} -gt 0 ]]; then
        printf "${RED}Error — missing required flags:${RESET}\n"
        printf '%s\n' "${errors[@]}"
        printf "Run with --help for usage.\n"
        exit 1
    fi

    print_summary

    local CONFIRMED
    ask_yes_no CONFIRMED "Submit?" "y"

    if [[ "$CONFIRMED" == false ]]; then
        printf "${YELLOW}  Aborted.${RESET}\n\n"
        exit 0
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# JSON value helper — empty/blank → null, otherwise escaped string
# ─────────────────────────────────────────────────────────────────────────────

json_val() {
    local v="$1"
    local stripped="${v//[[:space:]]/}"
    if [[ -z "$stripped" ]]; then
        printf 'null'
    else
        v="${v//\\/\\\\}"
        v="${v//\"/\\\"}"
        printf '"%s"' "$v"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Submit POST request
# ─────────────────────────────────────────────────────────────────────────────

submit() {
    local payload
    payload=$(printf '{
  "machine_name":  %s,
  "platform_name": %s,
  "ip_address":    %s,
  "bmc_name":      %s,
  "os":            %s,
  "description":   %s,
  "po_sms":        %s,
  "program":       %s,
  "socket":        %s,
  "system_config": %s,
  "make":          %s,
  "model":         %s,
  "category":      %s,
  "asset_owner":   %s,
  "serial":        %s,
  "maas_switch":   %s,
  "pdu_ip":        %s,
  "pdu_port":      %s,
  "site":          %s,
  "lab":           %s,
  "row_location":  %s,
  "rack":          %s,
  "ru":            %s,
  "cpu":           %s,
  "backplane":     %s,
  "jira":          %s
}' \
        "$(json_val "$MACHINE_NAME")" \
        "$(json_val "$PLATFORM_NAME")" \
        "$(json_val "$IP_ADDRESS")" \
        "$(json_val "$BMC_NAME")" \
        "$(json_val "$OS")" \
        "$(json_val "$DESCRIPTION")" \
        "$(json_val "$PO_SMS")" \
        "$(json_val "$PROGRAM")" \
        "$(json_val "$SOCKET")" \
        "$(json_val "$SYSTEM_CONFIG")" \
        "$(json_val "$MAKE")" \
        "$(json_val "$MODEL")" \
        "$(json_val "$CATEGORY")" \
        "$(json_val "$ASSET_OWNER")" \
        "$(json_val "$SERIAL")" \
        "$(json_val "$MAAS_SWITCH")" \
        "$(json_val "$PDU_IP")" \
        "$(json_val "$PDU_PORT")" \
        "$(json_val "$SITE")" \
        "$(json_val "$LAB")" \
        "$(json_val "$ROW_LOCATION")" \
        "$(json_val "$RACK")" \
        "$(json_val "$RU")" \
        "$(json_val "$CPU")" \
        "$(json_val "$BACKPLANE")" \
        "$(json_val "$JIRA")")

    printf "${CYAN}  Submitting to %s ...${RESET}\n" "$SERVER"

    local response http_body http_code curl_rc

    set +e
    response=$(curl -s -w "\n%{http_code}" \
        --connect-timeout 5 \
        -X POST "$SERVER/machines" \
        -H "Content-Type: application/json" \
        -d "$payload" 2>/dev/null)
    curl_rc=$?
    set -e

    if [[ $curl_rc -ne 0 ]]; then
        printf "${RED}  ✗  Cannot reach server at %s (curl exit %s)${RESET}\n\n" \
               "$SERVER" "$curl_rc" >&2
        exit 2
    fi

    http_body=$(echo "$response" | head -n -1)
    http_code=$(echo "$response" | tail -n 1)

    if [[ "$http_code" == "201" ]]; then
        printf "${GREEN}  ✓  Registered! %s${RESET}\n\n" "$http_body"
    else
        printf "${RED}  ✗  Failed (HTTP %s): %s${RESET}\n\n" "$http_code" "$http_body"
        exit 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

main() {
    if [[ $# -eq 0 ]]; then
        usage
    fi

    parse_args "$@"

    if [[ "$INTERACTIVE" == true ]]; then
        run_interactive
    else
        run_flag_mode
    fi

    submit
}

main "$@"
