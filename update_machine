}

# ─────────────────────────────────────────────────────────────────────────────
# Change summary — shows what will actually change
# Returns 0 if there are changes, 1 if nothing to do
# ─────────────────────────────────────────────────────────────────────────────

# Array of (label, variable_name, db_field_name) — used by summary and payload
FIELD_MAP=(
    "Machine name|NEW_NAME|machine_name"
    "Platform|NEW_PLATFORM|platform_name"
    "IP address|NEW_IP|ip_address"
    "BMC name|NEW_BMC|bmc_name"
    "OS|NEW_OS|os"
    "Description|NEW_DESC|description"
    "PO/SMS|NEW_PO_SMS|po_sms"
    "Program|NEW_PROGRAM|program"
    "Socket|NEW_SOCKET|socket"
    "System Config|NEW_SYSTEM_CONFIG|system_config"
    "Make|NEW_MAKE|make"
    "Model|NEW_MODEL|model"
    "Category|NEW_CATEGORY|category"
    "Asset Owner|NEW_ASSET_OWNER|asset_owner"
    "Serial|NEW_SERIAL|serial"
    "MaaS Switch|NEW_MAAS_SWITCH|maas_switch"
    "PDU IP|NEW_PDU_IP|pdu_ip"
    "PDU Port|NEW_PDU_PORT|pdu_port"
    "Site|NEW_SITE|site"
    "Lab|NEW_LAB|lab"
    "Row|NEW_ROW_LOCATION|row_location"
    "Rack|NEW_RACK|rack"
    "RU|NEW_RU|ru"
    "CPU|NEW_CPU|cpu"
    "Backplane|NEW_BACKPLANE|backplane"
    "JIRA|NEW_JIRA|jira"
)

print_change_summary() {
    echo ""
    printf "${BOLD}${CYAN}── Planned changes ──────────────────────────${RESET}\n"

    local any=false
    local entry label var_name db_field new_val old_val

    for entry in "${FIELD_MAP[@]}"; do
        IFS='|' read -r label var_name db_field <<< "$entry"
        eval new_val="\$$var_name"
        old_val=$(get_field "$db_field")

        if [[ -n "$new_val" && "$new_val" != "$old_val" ]]; then
            printf "  ${BOLD}%-20s${RESET} ${RED}%s${RESET}  →  ${GREEN}%s${RESET}\n" \
                   "$label:" "${old_val:-(none)}" "$new_val"
            any=true
        fi
    done

    printf "${BOLD}${CYAN}─────────────────────────────────────────────${RESET}\n"

    if [[ "$any" == false ]]; then
        printf "  ${YELLOW}No changes detected.${RESET}\n\n"
        return 1
    fi
    echo ""
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# JSON helpers
# ─────────────────────────────────────────────────────────────────────────────
json_val() {
    local v="$1"
    local stripped="${v//[[:space:]]/}"
    if [[ -z "$stripped" ]]; then
        printf 'null'
    else
        v="${v//\\/\\\\}"
        v="${v//\"/\\\"}"
        printf '"%s"' "$v"
    fi
}

build_payload() {
    local parts=()
    local entry label var_name db_field new_val

    for entry in "${FIELD_MAP[@]}"; do
        IFS='|' read -r label var_name db_field <<< "$entry"
        eval new_val="\$$var_name"

        if [[ -n "$new_val" ]]; then
            parts+=("\"${db_field}\": $(json_val "$new_val")")
        fi
    done

    if [[ ${#parts[@]} -eq 0 ]]; then
        echo ""
        return 1
    fi

    local payload="{"
    for i in "${!parts[@]}"; do
        payload+=" ${parts[$i]}"
        if (( i < ${#parts[@]} - 1 )); then
            payload+=","
        fi
    done
    payload+=" }"
    echo "$payload"
}

# ─────────────────────────────────────────────────────────────────────────────
# Submit PUT request
# ─────────────────────────────────────────────────────────────────────────────
do_update() {
    local payload
    set +e
    payload=$(build_payload)
    local build_rc=$?
    set -e

    if [[ $build_rc -ne 0 || -z "$payload" ]]; then
        printf "${YELLOW}  Nothing to update.${RESET}\n\n"
        exit 0
    fi

    printf "${CYAN}  Updating '%s' on %s ...${RESET}\n" "$CURRENT_NAME" "$SERVER"

    local response http_body http_code curl_rc

    set +e
    response=$(curl -s -w "\n%{http_code}" \
        --connect-timeout 5 \
        -X PUT "$SERVER/machines/$CURRENT_NAME" \
        -H "Content-Type: application/json" \
        -d "$payload" 2>/dev/null)
    curl_rc=$?
    set -e

    if [[ $curl_rc -ne 0 ]]; then
        printf "${RED}  ✗  Cannot reach server at %s${RESET}\n\n" "$SERVER" >&2
        exit 2
    fi

    http_body=$(echo "$response" | head -n -1)
    http_code=$(echo "$response" | tail -n 1)

    echo ""
    if [[ "$http_code" == "200" ]]; then
        printf "${GREEN}  ✓  Updated! %s${RESET}\n\n" "$http_body"
    elif [[ "$http_code" == "404" ]]; then
        printf "${RED}  ✗  Not found: '%s' does not exist.${RESET}\n\n" \
               "$CURRENT_NAME"
        exit 1
    elif [[ "$http_code" == "409" ]]; then
        printf "${RED}  ✗  Conflict: %s${RESET}\n\n" "$http_body"
        exit 1
    else
        printf "${RED}  ✗  Failed (HTTP %s): %s${RESET}\n\n" "$http_code" "$http_body"
        exit 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Interactive field entry — used by both initial entry and re-edit
# ─────────────────────────────────────────────────────────────────────────────
prompt_all_fields() {
    local use_new="${1:-false}"   # "true" = use NEW_ vars as defaults (re-edit)

    _current_or_new() {
        local var_name="$1" db_field="$2"
        if [[ "$use_new" == "true" ]]; then
            local nv
            eval nv="\$$var_name"
            if [[ -n "$nv" ]]; then
                echo "$nv"
                return
            fi
        fi
        get_field "$db_field"
    }

    echo ""
    printf "  ${CYAN}── Identity ──${RESET}\n"
    ask NEW_NAME     "New machine name (rename)"  "$(_current_or_new NEW_NAME machine_name)"
    clear_if_unchanged NEW_NAME machine_name
    ask NEW_PLATFORM "Platform name"              "$(_current_or_new NEW_PLATFORM platform_name)"
    clear_if_unchanged NEW_PLATFORM platform_name
    ask NEW_IP       "IP address"                 "$(_current_or_new NEW_IP ip_address)"
    clear_if_unchanged NEW_IP ip_address
    ask NEW_BMC      "BMC name"                   "$(_current_or_new NEW_BMC bmc_name)"
    clear_if_unchanged NEW_BMC bmc_name
    ask NEW_OS       "Operating system"           "$(_current_or_new NEW_OS os)"
    clear_if_unchanged NEW_OS os
    ask NEW_DESC     "Description"                "$(_current_or_new NEW_DESC description)"
    clear_if_unchanged NEW_DESC description

    echo ""
    printf "  ${CYAN}── Inventory ──${RESET}\n"
    ask NEW_PO_SMS        "PO/SMS"              "$(_current_or_new NEW_PO_SMS po_sms)"
    clear_if_unchanged NEW_PO_SMS po_sms
    ask NEW_PROGRAM       "Program"             "$(_current_or_new NEW_PROGRAM program)"
    clear_if_unchanged NEW_PROGRAM program
    ask NEW_SOCKET        "Socket"              "$(_current_or_new NEW_SOCKET socket)"
    clear_if_unchanged NEW_SOCKET socket
    ask NEW_SYSTEM_CONFIG "System Config"       "$(_current_or_new NEW_SYSTEM_CONFIG system_config)"
    clear_if_unchanged NEW_SYSTEM_CONFIG system_config
    ask NEW_MAKE          "Make"                "$(_current_or_new NEW_MAKE make)"
    clear_if_unchanged NEW_MAKE make
    ask NEW_MODEL         "Model"               "$(_current_or_new NEW_MODEL model)"
    clear_if_unchanged NEW_MODEL model
    ask NEW_CATEGORY      "Category"            "$(_current_or_new NEW_CATEGORY category)"
    clear_if_unchanged NEW_CATEGORY category
    ask NEW_ASSET_OWNER   "Asset Owner"         "$(_current_or_new NEW_ASSET_OWNER asset_owner)"
    clear_if_unchanged NEW_ASSET_OWNER asset_owner
    ask NEW_SERIAL        "Serial"              "$(_current_or_new NEW_SERIAL serial)"
    clear_if_unchanged NEW_SERIAL serial
    ask NEW_MAAS_SWITCH   "MaaS Switch"         "$(_current_or_new NEW_MAAS_SWITCH maas_switch)"
    clear_if_unchanged NEW_MAAS_SWITCH maas_switch
    ask NEW_PDU_IP        "PDU IP"              "$(_current_or_new NEW_PDU_IP pdu_ip)"
    clear_if_unchanged NEW_PDU_IP pdu_ip
    ask NEW_PDU_PORT      "PDU Port"            "$(_current_or_new NEW_PDU_PORT pdu_port)"
    clear_if_unchanged NEW_PDU_PORT pdu_port

    echo ""
    printf "  ${CYAN}── Location ──${RESET}\n"
    ask NEW_SITE          "Site"                "$(_current_or_new NEW_SITE site)"
    clear_if_unchanged NEW_SITE site
    ask NEW_LAB           "Lab"                 "$(_current_or_new NEW_LAB lab)"
    clear_if_unchanged NEW_LAB lab
    ask NEW_ROW_LOCATION  "Row"                 "$(_current_or_new NEW_ROW_LOCATION row_location)"
    clear_if_unchanged NEW_ROW_LOCATION row_location
    ask NEW_RACK          "Rack"                "$(_current_or_new NEW_RACK rack)"
    clear_if_unchanged NEW_RACK rack
    ask NEW_RU            "RU"                  "$(_current_or_new NEW_RU ru)"
    clear_if_unchanged NEW_RU ru

    echo ""
    printf "  ${CYAN}── Hardware / Tracking ──${RESET}\n"
    ask NEW_CPU           "CPU"                 "$(_current_or_new NEW_CPU cpu)"
    clear_if_unchanged NEW_CPU cpu
    ask NEW_BACKPLANE     "Backplane"           "$(_current_or_new NEW_BACKPLANE backplane)"
    clear_if_unchanged NEW_BACKPLANE backplane
    ask NEW_JIRA          "JIRA ticket"         "$(_current_or_new NEW_JIRA jira)"
