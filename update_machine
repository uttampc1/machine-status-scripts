#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# update_machine.sh  —  Update machine fields (NOT status/reservation)
#
# Usage:
#   Interactive:  ./update_machine.sh --interactive
#   Flag mode:    ./update_machine.sh -m worker-01 [-n name] [field flags]
#
# Required: -m (identifies the machine to update)
# Supply only the flags for fields you want to change.
#
# To update status/reservation use: update_machine_status.sh
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ── defaults ──────────────────────────────────────────────────────────────────
CONFIG_DIR="/usr/local/etc"
source ${CONFIG_DIR}/machines.config

# ── field variables ───────────────────────────────────────────────────────────
# ── current machine identifier ────────────────────────────────────────────────
CURRENT_NAME=""
INTERACTIVE=false

# ── new values (empty = not changing) ─────────────────────────────────────────
NEW_NAME=""
NEW_PLATFORM=""
NEW_IP=""
NEW_BMC=""
NEW_OS=""
NEW_DESC=""
NEW_PO_SMS=""
NEW_PROGRAM=""
NEW_SOCKET=""
NEW_SYSTEM_CONFIG=""
NEW_MAKE=""
NEW_MODEL=""
NEW_CATEGORY=""
NEW_ASSET_OWNER=""
NEW_SERIAL=""
NEW_MAAS_SWITCH=""
NEW_PDU_IP=""
NEW_PDU_PORT=""
NEW_SITE=""
NEW_LAB=""
NEW_ROW_LOCATION=""
NEW_RACK=""
NEW_RU=""
NEW_CPU=""
NEW_BACKPLANE=""
NEW_JIRA=""

# ── colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m';  GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m';     RESET='\033[0m'

# ── usage ─────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF

${BOLD}update_machine.sh${RESET} — Update machine fields (NOT status/reservation)
Server: ${SERVER}

${BOLD}INTERACTIVE MODE${RESET}
  $(basename "$0") --interactive

${BOLD}FLAG MODE${RESET}  (supply only flags for fields you want to change)
  $(basename "$0") -m <current_name> [field flags]

${BOLD}REQUIRED${RESET}
  -m   current machine name   (identifies the machine)

${BOLD}IDENTITY FLAGS${RESET}
  -n   new machine name       (rename)
  -p   platform name
  -i   IP address
  -b   BMC name
  -o   OS
  -d   description

${BOLD}INVENTORY FLAGS${RESET}
  --po-sms <val>        PO/SMS number
  --program <val>       program name
  --socket <val>        socket type
  --sys-config <val>    system configuration
  --make <val>          manufacturer
  --model <val>         model name
  --category <val>      category
  --asset-owner <val>   asset owner
  --serial <val>        serial number
  --maas-switch <val>   MaaS switch
  --pdu-ip <val>        PDU IP address
  --pdu-port <val>      PDU port
  --site <val>          site location
  --lab <val>           lab name
  --row <val>           row location
  --rack <val>          rack identifier
  --ru <val>            rack unit
  --cpu <val>           CPU type
  --backplane <val>     backplane type
  --jira <val>          JIRA ticket

${BOLD}OTHER${RESET}
  --interactive         guided prompt mode
  --help

${BOLD}NOTE${RESET}
  To reserve/release a machine use: update_machine_status.sh

${BOLD}EXAMPLES${RESET}
  $(basename "$0") --interactive
  $(basename "$0") -m worker-01 -i 10.0.1.55
  $(basename "$0") -m worker-01 -o "RHEL 9.4"
  $(basename "$0") -m worker-01 -n build-node-01
  $(basename "$0") -m worker-01 -p aarch64 -i 10.0.2.1 -o "RHEL 9.4"
  $(basename "$0") -m worker-01 --site Austin --rack R42 --cpu Turin
  $(basename "$0") -m worker-01 --jira PROJ-1234 --serial SN-ABC

EOF
    exit 0
}

# ─────────────────────────────────────────────────────────────────────────────
# Argument parsing
# ─────────────────────────────────────────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --interactive)    INTERACTIVE=true;         shift ;;
            --help|-h)        usage ;;
            -m)               CURRENT_NAME="$2";        shift 2 ;;
            -n)               NEW_NAME="$2";            shift 2 ;;
            -p)               NEW_PLATFORM="$2";        shift 2 ;;
            -i)               NEW_IP="$2";              shift 2 ;;
            -b)               NEW_BMC="$2";             shift 2 ;;
            -o)               NEW_OS="$2";              shift 2 ;;
            -d)               NEW_DESC="$2";            shift 2 ;;
            --po-sms)         NEW_PO_SMS="$2";          shift 2 ;;
            --program)        NEW_PROGRAM="$2";         shift 2 ;;
            --socket)         NEW_SOCKET="$2";          shift 2 ;;
            --sys-config)     NEW_SYSTEM_CONFIG="$2";   shift 2 ;;
            --make)           NEW_MAKE="$2";            shift 2 ;;
            --model)          NEW_MODEL="$2";           shift 2 ;;
            --category)       NEW_CATEGORY="$2";        shift 2 ;;
            --asset-owner)    NEW_ASSET_OWNER="$2";     shift 2 ;;
            --serial)         NEW_SERIAL="$2";          shift 2 ;;
            --maas-switch)    NEW_MAAS_SWITCH="$2";     shift 2 ;;
            --pdu-ip)         NEW_PDU_IP="$2";          shift 2 ;;
            --pdu-port)       NEW_PDU_PORT="$2";        shift 2 ;;
            --site)           NEW_SITE="$2";            shift 2 ;;
            --lab)            NEW_LAB="$2";             shift 2 ;;
            --row)            NEW_ROW_LOCATION="$2";    shift 2 ;;
            --rack)           NEW_RACK="$2";            shift 2 ;;
            --ru)             NEW_RU="$2";              shift 2 ;;
            --cpu)            NEW_CPU="$2";             shift 2 ;;
            --backplane)      NEW_BACKPLANE="$2";       shift 2 ;;
            --jira)           NEW_JIRA="$2";            shift 2 ;;
            *)
                printf "${RED}Unknown option: %s${RESET}\n" "$1" >&2
                printf "Run with --help for usage.\n" >&2
                exit 1
                ;;
        esac
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Prompt helpers
# ─────────────────────────────────────────────────────────────────────────────

ask() {
    local var="$1" prompt="$2" current="${3:-}" value=""

    if [[ -n "$current" ]]; then
        printf "${CYAN}?${RESET} ${BOLD}%-30s${RESET} ${YELLOW}[%s]${RESET}: " \
               "$prompt" "$current"
    else
        printf "${CYAN}?${RESET} ${BOLD}%-30s${RESET} ${YELLOW}[(none)]${RESET}: " \
               "$prompt"
    fi

    read -r value
    printf -v "$var" '%s' "$value"
}

ask_required() {
    local var="$1" prompt="$2" current="${3:-}"

    while true; do
        ask "$var" "$prompt" "$current"
        local val
        eval val="\$$var"

        # If user pressed Enter and there's a current value, keep it
        if [[ -z "$val" && -n "$current" ]]; then
            printf -v "$var" '%s' "$current"
            return
        fi

        local stripped="${val//[[:space:]]/}"
        if [[ -n "$stripped" ]]; then
            return
        fi
        printf "${RED}  ✗  This field cannot be blank.${RESET}\n"
    done
}

ask_yes_no() {
    local var="$1" prompt="$2" default="${3:-n}"
    local hint
    if [[ "$default" == "y" ]]; then
        hint="Y/n"
    else
        hint="y/N"
    fi

    while true; do
        printf "${CYAN}?${RESET} ${BOLD}%s${RESET} ${YELLOW}[%s]${RESET}: " \
               "$prompt" "$hint"
        local value=""
        read -r value
        if [[ -z "$value" ]]; then
            value="$default"
        fi

        case "${value,,}" in
            y|yes)  printf -v "$var" 'true';  return ;;
            n|no)   printf -v "$var" 'false'; return ;;
            *)      printf "${RED}  Please type y or n.${RESET}\n" ;;
        esac
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# Fetch machine from API
# ─────────────────────────────────────────────────────────────────────────────
fetch_machine() {
    local name="$1"
    local response http_body http_code curl_rc

    set +e
    response=$(curl -s -w "\n%{http_code}" \
        --connect-timeout 5 \
        -H "Accept: application/json" \
        "$SERVER/machines" 2>/dev/null)
    curl_rc=$?
    set -e

    if [[ $curl_rc -ne 0 ]]; then
        printf "${RED}Error: cannot reach server at %s (curl exit %s)${RESET}\n" \
               "$SERVER" "$curl_rc" >&2
        exit 2
    fi

    http_body=$(echo "$response" | head -n -1)
    http_code=$(echo "$response" | tail -n 1)

    if [[ "$http_code" != "200" ]]; then
        printf "${RED}Error: server at %s returned HTTP %s${RESET}\n" \
               "$SERVER" "$http_code" >&2
        exit 2
    fi

    local match py_rc
    set +e
    match=$(echo "$http_body" | python3 -c "
import sys, json
try:
    machines = json.load(sys.stdin)
except Exception as e:
    sys.stderr.write('parse_error\n')
    sys.exit(2)
target = sys.argv[1]
found = next((m for m in machines if m['machine_name'] == target), None)
if found is None:
    sys.exit(1)
print(json.dumps(found))
sys.exit(0)
" "$name" 2>/dev/null)
    py_rc=$?
    set -e

    case $py_rc in
        0)
            MACHINE_JSON="$match"
            return 0
            ;;
        1)
            printf "${RED}Error: machine '%s' not found.${RESET}\n" "$name" >&2
            exit 1
            ;;
        *)
            printf "${RED}Error: could not parse server response from %s${RESET}\n" \
                   "$SERVER" >&2
            exit 2
            ;;
    esac
}

get_field() {
    local field="$1"
    echo "$MACHINE_JSON" | python3 -c "
import sys, json
m = json.load(sys.stdin)
val = m.get('$field')
print(val if val is not None else '')
" 2>/dev/null
}

print_machine_details() {
    local label="${1:-Current values}"
    echo ""
    printf "${BOLD}${YELLOW}── %s ──────────────────────────${RESET}\n" "$label"
    echo "$MACHINE_JSON" | python3 -c "
import sys, json
m = json.load(sys.stdin)
fields = [
    ('Machine name',  'machine_name'),
    ('Platform',      'platform_name'),
    ('IP address',    'ip_address'),
    ('BMC name',      'bmc_name'),
    ('OS',            'os'),
    ('Status',        'status'),
    ('Reserved by',   'reserved_by'),
    ('Description',   'description'),
    ('PO/SMS',        'po_sms'),
    ('Program',       'program'),
    ('Socket',        'socket'),
    ('System Config', 'system_config'),
    ('Make',          'make'),
    ('Model',         'model'),
    ('Category',      'category'),
    ('Asset Owner',   'asset_owner'),
    ('Serial',        'serial'),
    ('MaaS Switch',   'maas_switch'),
    ('PDU IP',        'pdu_ip'),
    ('PDU Port',      'pdu_port'),
    ('Site',          'site'),
    ('Lab',           'lab'),
    ('Row',           'row_location'),
    ('Rack',          'rack'),
    ('RU',            'ru'),
    ('CPU',           'cpu'),
