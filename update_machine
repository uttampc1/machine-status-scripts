}

# ─────────────────────────────────────────────────────────────────────────────
# Clear a NEW_ variable if user typed same value as current DB value
# ─────────────────────────────────────────────────────────────────────────────
clear_if_unchanged() {
    local var_name="$1" db_field="$2"
    local new_val old_val
    eval new_val="\$$var_name"
    old_val=$(get_field "$db_field")

    if [[ "$new_val" == "$old_val" ]]; then
        printf -v "$var_name" ''
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Interactive mode
# ─────────────────────────────────────────────────────────────────────────────
run_interactive() {
    echo ""
    printf "${BOLD}${CYAN}════════════════════════════════════════════${RESET}\n"
    printf "${BOLD}${CYAN}  Update Machine Fields  —  %s${RESET}\n" "$SERVER"
    printf "${BOLD}${CYAN}════════════════════════════════════════════${RESET}\n"
    printf "  ${YELLOW}Press Enter to keep the current value.${RESET}\n"
    printf "  ${YELLOW}To update status/reservation use: update_machine_status.sh${RESET}\n"
    echo ""

    # find the machine
    while true; do
        ask_required CURRENT_NAME "Current machine name" "$CURRENT_NAME"
        printf "${CYAN}  Looking up '%s'...${RESET}\n" "$CURRENT_NAME"

        set +e
        fetch_machine "$CURRENT_NAME"
        local rc=$?
        set -e

        if [[ $rc -eq 0 ]]; then
            break
        fi
        # rc=1 means not found (fetch_machine printed the error)
        # rc=2 means server down (fetch_machine already exited)
        CURRENT_NAME=""
    done

	
    print_machine_details "Current values"
    printf "  ${YELLOW}(Press Enter to keep current value for each field)${RESET}\n"

    prompt_all_fields "false"

    # show what will change
    local summary_rc
    set +e
    print_change_summary
    summary_rc=$?
    set -e

    if [[ $summary_rc -ne 0 ]]; then
        printf "${YELLOW}  No changes made. Exiting.${RESET}\n\n"
        exit 0
    fi

    # confirm / edit / abort loop
    while true; do
        printf "${CYAN}?${RESET} ${BOLD}Apply these changes? [Y/n/edit]${RESET}: "
        local confirm_input=""
        read -r confirm_input
        case "${confirm_input,,}" in
            ""|y|yes)
                break
                ;;
            n|no|q)
                printf "${YELLOW}  Aborted. Nothing was changed.${RESET}\n\n"
                exit 0
                ;;
            e|edit)
                echo ""
                printf "${YELLOW}  Re-editing (current edits shown as defaults)...${RESET}\n"
                prompt_all_fields "true"

                set +e
                print_change_summary
                summary_rc=$?
                set -e

                if [[ $summary_rc -ne 0 ]]; then
                    printf "${YELLOW}  No changes. Exiting.${RESET}\n\n"
                    exit 0
                fi
                ;;
            *)
                printf "${RED}  Please type y, n, or edit.${RESET}\n"
                ;;
        esac
    done

    echo ""
    do_update
}

# ─────────────────────────────────────────────────────────────────────────────
# Flag mode
# ─────────────────────────────────────────────────────────────────────────────
run_flag_mode() {
    if [[ -z "$CURRENT_NAME" ]]; then
        printf "${RED}Error: -m current_machine_name is required.${RESET}\n"
        printf "Run with --help for usage.\n"
        exit 1
    fi

    # check at least one field is being changed
    local any_change=false
    local entry label var_name db_field val
    for entry in "${FIELD_MAP[@]}"; do
        IFS='|' read -r label var_name db_field <<< "$entry"
        eval val="\$$var_name"
        if [[ -n "$val" ]]; then
            any_change=true
            break
        fi
    done

    if [[ "$any_change" == false ]]; then
        printf "${YELLOW}Nothing to update. Supply at least one field flag.${RESET}\n"
        printf "Run with --help for usage.\n"
        exit 1
    fi

    printf "${CYAN}  Looking up '%s'...${RESET}\n" "$CURRENT_NAME"

    set +e
    fetch_machine "$CURRENT_NAME"
    local rc=$?
    set -e

    if [[ $rc -ne 0 ]]; then
        # fetch_machine already printed the error message
        exit $rc
    fi

    print_machine_details "Current values"

    # show what will change
    local summary_rc
    set +e
    print_change_summary
    summary_rc=$?
    set -e

    if [[ $summary_rc -ne 0 ]]; then
        printf "${YELLOW}  No effective changes detected. Exiting.${RESET}\n\n"
        exit 0
    fi

    # confirm if running in a terminal
    if [[ -t 0 ]]; then
        local CONFIRMED
        ask_yes_no CONFIRMED "Apply these changes?" "y"
        if [[ "$CONFIRMED" == false ]]; then
            printf "${YELLOW}  Aborted.${RESET}\n\n"
            exit 0
        fi
        echo ""
    fi

    do_update
}

# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────
main() {
    if [[ $# -eq 0 ]]; then
        usage
    fi

    parse_args "$@"

    if [[ "$INTERACTIVE" == true ]]; then
        run_interactive
    else
        run_flag_mode
    fi
}

main "$@"
