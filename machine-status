#!/bin/bash
PROGNAME=$(basename -- "$0") #`basename $0`
DATE=`date`
TARGET_MSG="/usr/local/etc/machine-status.msg"
STATUS_TEMPLATE="/usr/local/etc/machine-status.template"

BG_RED='\033[41m'
BG_NONE='\033[49m'
BOLD_WHITE='\033[1;37m'
BOLD_RED='\033[1;31m'
BOLD_GREEN='\033[1;32m'
RESET='\033[0m'
BLINK='\033[5m'

show_usage() {
  printf "Usage:\n"
  printf "\t$ machine-status                -- To check machine status.\n"
  printf "\t$ machine-reserve <Name|email>  -- To reserve.\n"
  printf "\t$ machine-release               -- To release\n"
  printf "\t$ machine-report                -- Simple text report\n"

  printf "Note:\n"
  printf "\t** If reserved, contact current owner before reserving or using it.\n"
}

show_red() {
  local msg=$1
  local dt=$2
  printf '\n'
  printf "${BOLD_RED}=============================================${RESET}\n"
  printf '\n'
  printf "${BOLD_RED}>>>> ${msg}${RESET}\n"
  printf "${BOLD_WHITE}Since:${dt}${RESET}\n"
  printf '\n'
  show_usage
}

show_green() {
  local dt=$1
  printf '\n'
  printf "${BOLD_GREEN}=============================================${RESET}\n"
  printf '\n'
  printf "${BOLD_GREEN}>>>> Machine is available <<<<${RESET}\n"
  printf "${BOLD_WHITE}Since:${dt} ${RESET}\n"
  printf '\n'
  show_usage
}

if [ "$PROGNAME" == "machine-reserve" ]; then
  username=$USER
  if [ "x${1}" != "x" ]; then
    username=$1
  fi
  if [ -f $TARGET_MSG ]; then
    x=`grep "Reserved by" $TARGET_MSG`
    if [ "x${x}" != "x" ]; then
      n="$(echo "${x}" | sed -e 's/^[[:space:]]*//' | sed -e 's/^*[[:space:]]*//')"
      currentOwner=`echo $n|awk '{print $3}'`
      # Simple STOP box
      printf '\n'
      printf "\t${BG_RED}${BOLD_WHITE}  ╔══════════════════════╗  ${RESET}\n"
      printf "\t${BG_RED}${BOLD_WHITE}  ║                      ║  ${RESET}\n"
      printf "\t${BG_RED}${BOLD_WHITE}  ║     ⛔  STOP!  ⛔    ║  ${RESET}\n"
      printf "\t${BG_RED}${BOLD_WHITE}  ║                      ║  ${RESET}\n"
      printf "\t${BG_RED}${BOLD_WHITE}  ╚══════════════════════╝  ${RESET}\n"
      printf '\n'

      # Optional: blinking warning (some terminals support this)
      printf '\n'
      printf "\t${BLINK}${BOLD_RED}${n}${RESET}\n"
      printf '\n'
      echo 
      while true;
      do
        read -r -p "WARNING: Do you still want to proceed? (Yes or No)? " response
        if [[ $response =~ ^([yY]|[nN])$ ]]; then
          echo "INFO: Please enter yes or no"
          continue
        fi
        if [[ $response =~ ^([yY][eE][sS]|[yY])$ ]]; then
          echo
          printf "WARNING: Please inform ${BG_RED}${currentOwner}${RESET} about your reservation\n"
          while true;
          do
            read -r -p "WARNING: Continue with reservation? (Yes or No)? " response
            if [[ $response =~ ^([yY]|[nN])$ ]]; then
              echo "INFO: Please enter yes or no"
              continue
            elif [[ $response =~ ^([yY][eE][sS]|[yY])$ ]]; then
             echo "INFO: Ok, we will proceed."
             break;
            else
              echo "Exiting ..."
              echo
              exit 0
            fi
           done
          break
        else
          echo "Exiting ..."
          echo
          exit 0
        fi
      done
    fi
  fi 
  sed -e "s/STATUS/Reserved by $username/g" -e "s/DATE/Date: $DATE/g" ${STATUS_TEMPLATE} > ${TARGET_MSG}
  wall "WARNING: Machine is reserved by $username."
  wall "INFO: Use machine-status command to see the latest status."
  echo "$DATE:Reserved by $username" >> /var/log/machine-status.log
  show_red "${username}: Machine is now reserved for you!" " ${DATE}"
elif [ "$PROGNAME" == "machine-release" ]; then
  sed -e "s/STATUS/Available/g" -e "s/DATE/Date: $DATE/g" ${STATUS_TEMPLATE} > ${TARGET_MSG}
  show_green " ${DATE}"
  echo "$DATE:Released" >> /var/log/machine-status.log
elif [ "$PROGNAME" == "machine-report" ]; then
  tail -n 25 /var/log/machine-status.log
  exit
else
  dt=`grep "Date: " $TARGET_MSG | cut -d':' -f2-`
  x=`grep "Reserved by" $TARGET_MSG`
  if [ "x${x}" != "x" ]; then
    n="$(echo "${x}" | sed -e 's/^[[:space:]]*//' | sed -e 's/^*[[:space:]]*//')"
    show_red "${n}" "${dt}"
  else
    show_green "${dt}"
  fi
fi
echo
